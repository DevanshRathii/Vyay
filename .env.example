# ── Core ────────────────────────────────────────────────────────────────────
# Public URL of the app (no trailing slash). Used for OAuth redirects.
APP_URL=http://localhost:3000

# Secret used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=

# 32-byte key (base64) used to encrypt Gmail OAuth tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Supabase Postgres — transaction pooler (port 6543), used by the app runtime.
DATABASE_URL=
# Supabase Postgres — used only by migrations (`npx tsx migrate.ts`).
# Direct connection (port 5432) works locally, but on Vercel's build
# containers it fails with ENETUNREACH — the direct host is IPv6-only and
# Vercel's builders have no outbound IPv6. Use the SESSION pooler instead
# (also port 5432, different host/username — see Supabase dashboard →
# Connect → "Session pooler"). Never use the TRANSACTION pooler (port
# 6543, same as DATABASE_URL) here — it breaks migrations' need for
# session-scoped/prepared statements.
MIGRATE_DATABASE_URL=

# Secret required to call the daily sync cron route (/api/cron/sync).
# Vercel sends it automatically as an Authorization: Bearer header.
CRON_SECRET=

# ── Access control & notifications (optional) ───────────────────────────────
# Plain "Continue with Google" sign-in is ALWAYS open to any Google account —
# Google never restricts non-sensitive scopes like basic profile/email, even
# while this app is unverified. The actually-restricted step is connecting
# Gmail (the sensitive gmail.readonly scope), which Google gates via the
# OAuth consent screen's "Test users" list. Vyay layers its own gate in front
# of that: a new sign-up can't even attempt Gmail-connect until you grant
# them access from /admin — but you must ALSO add them to the Google Test
# users list yourself in Cloud Console (Google Auth Platform > Audience);
# there's no API for that step, so /admin can't do it for you.
#
# This env var is who /admin is restricted to, and whose own first sign-in
# skips the "new user" notification below.
ADMIN_EMAIL=
# A Gmail App Password for ADMIN_EMAIL — when set (together with
# ADMIN_EMAIL), a new sign-up or "urgent feedback" submission sends a real
# email from and to that address via Gmail SMTP. Needs 2-Step Verification
# enabled on the account first, then generate one at
# https://myaccount.google.com/apppasswords (name it e.g. "Vyay"). This is a
# 16-character app-specific password, NOT your normal Google password.
ADMIN_GMAIL_APP_PASSWORD=
# Optional, in addition to (or instead of) email above — POSTed as JSON
# `{ text, content }` (Slack/Discord-shaped) on the same two events. Point it
# at a Slack/Discord incoming webhook, ntfy.sh topic, or any endpoint that
# can relay a JSON POST onward. Leave both this and the app password unset
# to skip notifications entirely (new sign-ups still show up in /admin).
ADMIN_NOTIFY_WEBHOOK_URL=
# Optional — your Google Cloud project id/number. When set, the "Add to
# Google Test users" link on /admin deep-links straight to your project's
# Audience page instead of the generic Google Cloud Console entry point.
# Exposed to the browser (NEXT_PUBLIC_) since it's just a link target, not a
# secret.
NEXT_PUBLIC_GOOGLE_CLOUD_PROJECT=

# ── Google OAuth (required — sign-in is Google-only) ────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Add BOTH redirect URIs:
#   {APP_URL}/api/auth/callback/google   (Google login)
#   {APP_URL}/api/gmail/callback         (Gmail connection)
# Leaving these blank disables sign-in entirely, not just Gmail sync.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sync tuning (optional) ──────────────────────────────────────────────────
# How far back the first Gmail sync looks, as a rolling window of months.
# Leave unset to instead pull everything since a fixed anchor (1-Jan-2026).
SYNC_LOOKBACK_MONTHS=
# Background sync interval in minutes (0 disables background sync).
SYNC_INTERVAL_MINUTES=15
# Safety cap on messages fetched during the initial sync.
SYNC_MAX_INITIAL_MESSAGES=3000
# Extra Gmail search terms appended to the sync query, e.g. "from:(mybank.com)"
EXTRA_GMAIL_QUERY=
